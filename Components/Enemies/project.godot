; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Session 2"
run/main_scene="res://Everything.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
boot_splash/bg_color=Color(0.14, 0.14, 0.14, 0)
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

Global="*res://Global.gd"

[display]

window/size/viewport_width=1340
window/size/viewport_height=900
window/size/initial_position_type=0
window/subwindows/embed_subwindows=false
window/per_pixel_transparency/allowed=true

[global_group]

"Beat Progress Bar"=""
"Next Beat Button"=""
"Bar 1"=""
"Bar 2"=""
"Bar 3"=""
"Bar 4"=""
worldfilter=""
"Sub Bar 1"=""
"Sub Bar 2"=""
"Sub Bar 4"=""
"Sub Bar 3"=""
counter=""
"Player Speed Buttons"=""
"Player Swing Buttons"=""
"Bar 5"=""
"Sub Bar 5"=""
bg=""
"drag buttons"=""
global_recieve=""

[input]

"Random Beat"={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"window_id":0,"command_or_control_autoremap":true,"alt_pressed":false,"shift_pressed":false,"pressed":false,"keycode":0,"physical_keycode":82,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
